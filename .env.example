# ---------- Backend ----------
# Path to the player statistics CSV (relative to the backend working dir)
CSV_PATH=data/players.csv
# Port the FastAPI server listens on
BACKEND_PORT=8000
# Comma-separated list of origins allowed to call the API (frontend URL)
CORS_ORIGINS=http://localhost:5173

# ---------- Frontend ----------
# Host port the frontend is served on (container listens on 80)
FRONTEND_PORT=5173
# Base URL the React app uses to reach the backend (baked in at build time)
VITE_API_BASE_URL=http://localhost:8000
